# ============================================================================
#  متجر الكتب الرقمية — نموذج متغيرات البيئة
#  انسخ هذا الملف إلى .env واملأ القيم الحقيقية.
#  لا ترفع ملف .env إلى GitHub أبدًا — فهو يحتوي على أسرار حساسة.
# ============================================================================

# ---------- قاعدة البيانات (PostgreSQL) ----------
# عند التشغيل عبر docker-compose استخدم اسم الخدمة "db" كمضيف.
POSTGRES_USER=bookstore
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=bookstore
DATABASE_URL="postgresql://bookstore:change_me_strong_password@db:5432/bookstore?schema=public"

# ---------- عنوان الموقع العام ----------
# الدومين الفرعي على هوستنجر، مثال: https://books.example.com
NEXT_PUBLIC_SITE_URL=https://books.example.com
NEXT_PUBLIC_SITE_NAME=مكتبة محمد المسقري

# ---------- مفتاح توقيع الجلسات والرموز ----------
# ولّد قيمة عشوائية طويلة: openssl rand -base64 48
AUTH_SECRET=change_me_long_random_secret_value

# ---------- حساب المدير (المؤلف) ----------
# يُنشأ تلقائيًا عند أول تشغيل عبر سكربت البذور (seed).
ADMIN_EMAIL=author@example.com
ADMIN_PASSWORD=ChangeMeStrongAdminPass123
ADMIN_NAME=محمد المسقري

# ---------- PayPal ----------
# من لوحة مطوري PayPal: https://developer.paypal.com/dashboard/applications
# استخدم "live" للإنتاج و "sandbox" للتجارب.
PAYPAL_ENV=sandbox
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# عملة العرض الافتراضية (PayPal لا يدعم العملات الخليجية مباشرة غالبًا، استخدم USD).
NEXT_PUBLIC_CURRENCY=USD

# ---------- Resend (البريد) ----------
# من https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
# يجب أن يكون النطاق موثّقًا في Resend.
EMAIL_FROM="مكتبة محمد المسقري <no-reply@example.com>"
EMAIL_REPLY_TO=author@example.com

# ---------- تخزين الملفات المرفوعة ----------
# مسار داخل الحاوية يُربط بحجم دائم (volume) في docker-compose.
UPLOAD_DIR=/app/uploads
