// ============================================================================
//  مخطط قاعدة البيانات — متجر الكتب الرقمية
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// المدير (المؤلف) — حساب واحد أو أكثر لإدارة المتجر
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// الكتاب الرقمي
model Book {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  subtitle    String?
  author      String   @default("محمد المسقري")
  description String   @db.Text
  // السعر بالسنت لتفادي مشاكل الفاصلة العشرية (USD افتراضيًا)
  priceCents  Int      @default(0)
  currency    String   @default("USD")
  isFree      Boolean  @default(false)
  isPublished Boolean  @default(true)
  featured    Boolean  @default(false)
  // أسماء الملفات داخل مجلد الرفع
  coverFile   String?
  bookFile    String?
  fileSize    Int? // بالبايت
  pages       Int?
  language    String   @default("ar")
  category    String?
  // فهرس الفصول (سطر لكل فصل) يظهر في صفحة الكتاب
  chapters    String?  @db.Text
  // السلسلة التي ينتمي إليها الكتاب وترتيبه فيها
  series      Series?  @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  seriesId    String?
  seriesOrder Int      @default(0)
  // ترتيب العرض
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders         Order[]
  freeClaims     FreeClaim[]
  downloadTokens DownloadToken[]
  reviews        Review[]

  @@index([isPublished, isFree])
  @@index([featured])
  @@index([seriesId])
  @@index([category])
}

// مراجعة/تقييم قارئ لكتاب
model Review {
  id        String   @id @default(cuid())
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  bookId    String
  name      String
  rating    Int      @default(5)
  comment   String?  @db.Text
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([bookId, approved])
}

// سلسلة كتب تجمع عدة كتب بترتيب قراءة موصى به
model Series {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String?  @db.Text
  isPublished     Boolean  @default(true)
  sortOrder       Int      @default(0)
  // سعر الحزمة (السلسلة كاملة) بالسنت — 0 يعني لا عرض حزمة
  bundlePriceCents Int     @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  books  Book[]
  orders Order[]
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  PAYPAL
  BANK
}

enum CouponType {
  PERCENT // خصم نسبة مئوية (value = 1..100)
  FIXED   // خصم مبلغ ثابت بالسنت (value = عدد السنتات)
}

// طلب شراء (PayPal أو تحويل بنكي)
model Order {
  id              String        @id @default(cuid())
  book            Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)
  bookId          String
  // للطلبات من نوع حزمة سلسلة: السلسلة المشتراة (bookId يشير لأول كتاب فيها)
  series          Series?       @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  seriesId        String?
  customerName    String
  customerEmail   String
  amountCents     Int
  currency        String        @default("USD")
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod @default(PAYPAL)
  paypalOrderId   String?       @unique
  paypalCaptureId String?
  bankReference   String? // مرجع/ملاحظة التحويل البنكي من العميل
  couponCode      String? // رمز الكوبون المطبَّق (إن وُجد)
  discountCents   Int           @default(0) // قيمة الخصم المطبّق بالسنت
  referralCode    String? // رمز الإحالة الذي جاء عبره الطلب (إن وُجد)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  downloadTokens DownloadToken[]

  @@index([status])
  @@index([customerEmail])
}

// إعدادات المتجر (مفتاح/قيمة) يضبطها المدير من لوحة التحكم
model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// كوبون خصم يطبّقه العميل عند الشراء (PayPal أو تحويل بنكي)
model Coupon {
  id          String     @id @default(cuid())
  code        String     @unique // يُخزَّن بأحرف كبيرة
  description String? // وصف داخلي اختياري للمدير
  type        CouponType @default(PERCENT)
  value       Int // نسبة مئوية (1-100) أو مبلغ ثابت بالسنت
  active      Boolean    @default(true)
  maxUses     Int? // فارغ = غير محدود
  usedCount   Int        @default(0)
  minCents    Int        @default(0) // أدنى مبلغ طلب لتفعيل الكوبون (بالسنت)
  expiresAt   DateTime? // فارغ = لا تنتهي
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([active])
}

// شريك إحالة: يملك رمزًا يكسب عمولة على كل عملية شراء تتم عبر رابطه
model Referral {
  id                String   @id @default(cuid())
  code              String   @unique // يُخزَّن بأحرف كبيرة
  name              String
  email             String?
  commissionPercent Int      @default(20) // نسبة العمولة على مبلغ الطلب
  clicks            Int      @default(0)
  orders            Int      @default(0) // عدد عمليات الشراء المكتملة عبر الرمز
  earningsCents     Int      @default(0) // إجمالي العمولة المستحقّة بالسنت
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([active])
}

// مقال في المدونة التوعوية
model Post {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  content     String    @db.Text
  coverFile   String?
  isPublished Boolean   @default(true)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isPublished])
}

// تسجيل للحصول على كتاب مجاني (مع تأكيد البريد المزدوج)
model FreeClaim {
  id           String    @id @default(cuid())
  book         Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  bookId       String
  name         String
  email        String
  confirmed    Boolean   @default(false)
  confirmToken String    @unique
  confirmedAt  DateTime?
  // قبول استلام التحديثات (نشرة بريدية)
  optInUpdates Boolean   @default(true)
  ipAddress    String?
  createdAt    DateTime  @default(now())

  downloadTokens DownloadToken[]

  // لا يسمح بتسجيل البريد نفسه للكتاب نفسه مرتين
  @@unique([bookId, email])
  @@index([confirmed])
}

// رمز تحميل آمن لمرّات محدودة وبصلاحية زمنية
model DownloadToken {
  id            String     @id @default(cuid())
  token         String     @unique
  book          Book       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  bookId        String
  email         String
  order         Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId       String?
  freeClaim     FreeClaim? @relation(fields: [freeClaimId], references: [id], onDelete: SetNull)
  freeClaimId   String?
  maxDownloads  Int        @default(6)
  downloadCount Int        @default(0)
  expiresAt     DateTime
  createdAt     DateTime   @default(now())

  @@index([token])
}
